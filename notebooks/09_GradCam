lucional\n","    grad_model = tf.keras.Model(\n","        inputs=[base_model.inputs],\n","        outputs=[last_conv_layer.output, base_model.output]\n","    )\n","\n","    # Calcular gradientes\n","    with tf.GradientTape() as tape:\n","        conv_outputs, predictions = grad_model(img_array)\n","        top_pred_index = tf.argmax(predictions[0])\n","        class_output = predictions[:, top_pred_index]\n","\n","    # Gradientes de la clase con respecto a la salida del feature map\n","    grads = tape.gradient(class_output, conv_outputs)\n","\n","    # Vector de importancia global\n","    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))\n","\n","    # Multiplicar cada canal por su importancia\n","    conv_outputs = conv_outputs[0]\n","    heatmap = tf.reduce_sum(tf.multiply(pooled_grads, conv_outputs), axis=-1)\n","\n","    # Normalizar el heatmap\n","    heatmap = tf.maximum(heatmap, 0) / tf.math.reduce_max(heatmap)\n","    heatmap = heatmap.numpy()\n","\n","    # Redimensionar el heatmap al tamaño de la imagen original\n","    heatmap = tf.image.resize(\n","        heatmap[..., tf.newaxis],\n","        cfg.img_size[:2],\n","        method='bilinear'\n","    ).numpy()[:,:,0]\n","\n","    return heatmap, original_img"],"metadata":{"id":"DtZbr7ofcK8Y"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["AUTOTUNE = tf.data.AUTOTUNE\n","\n","def read_image(path_img):\n","    img_data = tf.io.read_file(path_img)\n","    img = tf.io.decode_jpeg(img_data, channels=cfg.channels)\n","    # Redimensionar la imagen a las dimensiones deseadas\n","    img = tf.image.resize(img, cfg.img_size)\n","    img = tf.cast(img, tf.float32)\n","    return img\n","\n","from sklearn.preprocessing import LabelEncoder\n","label_encoder = LabelEncoder()\n","label_encoder.fit(df.label)\n","\n","def decode_label(label):\n","    integer_encoded = label_encoder.transform(label)\n","    return tf.one_hot(integer_encoded, depth=cfg.n_label)"],"metadata":{"id":"I5IXtt_c7ac3"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def create_dataset(data, include_label=True, repeat=False, shuffle=False, augment=False, prefetch=False, batch_size=None):\n","    slices = data[\"path_img\"].values\n","    read_func = read_image\n","    if include_label:\n","        slices = slices, decode_label(data[cfg.label].values)\n","        read_func = lambda path_img, label: (read_image(path_img), label)\n","    ds = tf.data.Dataset.from_tensor_slices(slices)\n","    ds = ds.map(read_func, num_parallel_calls=AUTOTUNE)\n","    ds = ds.cache()\n","    if batch_size: ds = ds.batch(batch_size)\n","    if prefetch: ds = ds.prefetch(AUTOTUNE)\n","    return ds\n","\n","def create_validation_dataset(data):\n","    return create_dataset(\n","        data,\n","        include_label=True,\n","        prefetch=True,\n","        batch_size=cfg.valid_batch_size,\n","    )"],"metadata":{"id":"4sQ3Z9aHEcfn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["random = np.random.randint(0, df.shape[0])\n","print(f'Specie: {df.label[random]}\\n')\n","img_path = df['path_img'][random]\n","display(Image(img_path))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":180},"id":"Ws1H4mlO3-Zp","executionInfo":{"status":"ok","timestamp":1739645199377,"user_tz":300,"elapsed":4,"user":{"displayName":"Camilo Cortés","userId":"12108613151085381107"}},"outputId":"91527575-666d-4ce1-b406-45fc42366bc5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Specie: Buthraupis montana\n","\n"]},{"output_type":"display_data","data":{"image/jpeg":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}]},{"cell_type":"code","source":["eval_ds = create_validation_dataset(df.iloc[[random]])\n","eval_ds"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"1YPqq2GW4L5r","executionInfo":{"status":"ok","timestamp":1739645200114,"user_tz":300,"elapsed":501,"user":{"displayName":"Camilo Cort