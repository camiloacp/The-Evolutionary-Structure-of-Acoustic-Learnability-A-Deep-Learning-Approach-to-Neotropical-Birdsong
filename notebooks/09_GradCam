f `inputs` doesn't match the expected structure.\n","Expected: [['keras_tensor_7']]\n","Received: inputs=Tensor(shape=(1, 128, 256, 3))\n","  warnings.warn(msg)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["from tensorflow.keras.preprocessing.image import load_img, img_to_array\n","\n","@tf.custom_gradient\n","def guided_relu(x):\n","    def grad(dy):\n","        return tf.cast(dy > 0, \"float32\") * tf.cast(x > 0, \"float32\") * dy\n","    return tf.nn.relu(x), grad\n","\n","class GuidedBackpropReLU(tf.keras.layers.Layer):\n","    def __init__(self, layer, **kwargs):\n","        super(GuidedBackpropReLU, self).__init__(**kwargs)\n","        self.layer = layer\n","\n","    def call(self, inputs):\n","        return guided_relu(inputs)\n","\n","def create_guided_model(model):\n","    \"\"\"Crea un nuevo modelo para Guided Backprop\"\"\"\n","    # Obtener el modelo base EfficientNet\n","    base_model = model.get_layer(\"efficientnetb7\")\n","\n","    # Crear un nuevo modelo de entrada\n","    input_layer = tf.keras.Input(shape=cfg.img_size + (3,))\n","\n","    # Aplicar el preprocesamiento\n","    x = tf.keras.applications.efficientnet.preprocess_input(input_layer)\n","\n","    # Pasar por el modelo base modificando las ReLUs\n","    for layer in base_model.layers:\n","        if isinstance(layer, tf.keras.layers.ReLU):\n","            x = GuidedBackpropReLU(layer)(x)\n","        else:\n","            try:\n","                x = layer(x)\n","            except:\n","                # Si la capa falla, intentar preservar la forma de la salida\n","                if hasattr(layer, 'output_shape'):\n","                    x = tf.keras.layers.Lambda(\n","                        lambda inputs: layer(inputs),\n","                        output_shape=layer.output_shape[1:]\n","                    )(x)\n","                else:\n","                    x = x  # Mantener la entrada sin cambios si no podemos manejar la capa\n","\n","    return tf.keras.Model(inputs=input_layer, outputs=x)\n","\n","def generate_guided_gradcam(model, img_path, layer_name=\"top_conv\"):\n","    # Preparar la imagen\n","    img = load_img(img_path, target_size=cfg.img_size)\n","    img_array = img_to_array(img)\n","    img_array = np.expand_dims(img_array, axis=0)\n","\n","    # Guardar imagen original\n","    original_img = np.array(img)\n","\n","    # Crear modelo guiado\n","    guided_model = create_guided_model(model)\n","\n","    # Obtener la última capa convolucional\n","    base_model = model.get_layer(\"efficientnetb7\")\n","    last_conv_layer = base_model.get_layer(layer_name)\n","\n","    # Crear modelo para GradCAM\n","    grad_model = tf.keras.Model(\n","        inputs=[base_model.inputs],\n","        outputs=[last_conv_layer.output, base_model.output]\n","    )\n","\n","    # Calcular GradCAM\n","    with tf.GradientTape() as tape:\n","        conv_outputs, predictions = grad_model(tf.keras.applications.efficientnet.preprocess_input(img_array))\n","        top_pred_index = tf.argmax(predictions[0])\n","        class_output = predictions[:, top_pred_index]\n","\n","    # Gradientes para GradCAM\n","    grads = tape.gradient(class_output, conv_outputs)\n","    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))\n","    conv_outputs = conv_outputs[0]\n","    heatmap = tf.reduce_sum(tf.multiply(pooled_grads, conv_outputs), axis=-1)\n","    heatmap = tf.maximum(heatmap, 0) / tf.math.reduce_max(heatmap)\n","\n","    # Calcular Guided Backprop\n","    with tf.GradientTape() as tape:\n","        inputs = tf.cast(img_array, tf.float32)\n","        tape.watch(inputs)\n","        outputs = guided_model(inputs)\n","\n","        if isinstance(outputs, dict):\n","            outputs = outputs['predictions']\n","\n","        if len(outputs.shape) > 2:\n","            outputs = tf.keras.layers.GlobalAveragePooling2D()(outputs)\n","\n","        top_pred = outputs[:, top_pred_index]\n","\n","    guided_grads = tape.gradient(top_pred, inputs)[0]\n","\n","    # Redimensionar heatmap\n","    heatmap = tf.image.resize(\n","        heatmap[..., tf.newaxis],\n","        cfg.img_size[:2],\n","        method='bilinear'\n","    ).numpy()[:,:,0]\n","\n","    # Crear Guided Grad-CAM\n","    guided_gradcam = guided_grads * heatmap[..., tf.newaxis]\n","\n","    # Normalizar para visualización\n","    guided_gradcam = np.maximum(guided_gradcam, 0) / (np.max(guided_gradcam) + 1e-10)\n","\n","    return heatmap, guided_gradcam, original_img\n","\n","def visualize_guided_gradcam(heatmap, guided_gradcam, original_img):\n","    plt.figure(figsize=(15, 5))\n","\n","    plt.subplot(1, 3, 1)\n","    plt.imshow(original_img)\n","    plt.title('Original Image')\n","    plt.axis('off')\n","\n","    plt.subplot(1, 3, 2)\n","    plt.imshow(original_img)\n","    plt.imshow(heatmap, alpha=0.6, cmap='jet')\n","    plt.title('GradCAM')\n","    plt.axis('off')\n","\n","    plt.subplot(1, 3, 3)\n","    plt.imshow(np.mean(guided_gradcam, axis=-1), cmap='viridis')\n","    plt.title('Guided Grad-CAM')\n","    plt.axis('off')\n","\n","    plt.show()\n","\n","# Uso\n","heatmap, guided_gradcam, original_img = generate_guided_gradcam(model, img_path)\n","visualize_guided_gradcam(heatmap, guided_gradcam, original_img)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":250},"id":"ZijZP4tY3LN4","executionInfo":{"status":"ok","timestamp":1739645468796,"user_tz":300,"elapsed":6400,"user":{"displayName":"Camilo Cortés","userId":"12108613151085381107"}},"outputId":"3406f7df-09a9-4068-f524-679164c7caa6"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x500 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"ndOq7Zw77nF0"},"execution_count":null,"outputs":[]}]}
